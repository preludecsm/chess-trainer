      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git commit -m *)",

      "Bash(docker build *)",
      "Bash(docker push *)",
      "Bash(docker logs *)",
      "Bash(docker ps*)",
      "Bash(docker images*)",

      "Bash(aws sts get-caller-identity*)",
      "Bash(aws ec2 describe-*)",
      "Bash(aws ecr get-login-password*)",
      "Bash(aws iam list-*)",
      "Bash(aws iam get-*)",
      "Bash(aws sesv2 list-*)",

